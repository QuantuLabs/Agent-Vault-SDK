{
  "name": "@quantulabs/agent-vault",
  "version": "0.1.0",
  "description": "TypeScript SDK for Agent Vault: multi-wallet PDA management for 8004 agents on Solana.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "dist/scripts/*.js",
    "dist/scripts/*.js.map",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json && tsc -p tsconfig.scripts.json",
    "test": "tsx tests/pda.test.ts",
    "e2e:devnet": "node dist/scripts/e2e-devnet.js",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "check": "npm run build && npm run test"
  },
  "keywords": [
    "solana",
    "agent-vault",
    "8004",
    "agents",
    "wallet",
    "pda",
    "defi",
    "metaplex-core"
  ],
  "author": "Quantu Labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuantuLabs/Agent-Vault-SDK.git"
  },
  "homepage": "https://github.com/QuantuLabs/Agent-Vault-SDK#readme",
  "bugs": {
    "url": "https://github.com/QuantuLabs/Agent-Vault-SDK/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^20.10.6",
    "8004-solana": "^0.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
